# Copy this to .env for local development
# NEVER commit .env to git

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string-in-production
SECURITY_PASSWORD_SALT=another-random-string-keep-secret

# Database
# Development (SQLite — no change needed):
# DATABASE_URL is not set; app uses sqlite:///database.sqlite3

# Production (PostgreSQL — set this on Render/Railway):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS — comma-separated list of allowed frontend origins
# Development:
ALLOWED_ORIGINS=*
# Production example:
# ALLOWED_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# Optional Redis cache (leave blank to use in-process SimpleCache)
# REDIS_URL=redis://localhost:6379/0

# Gunicorn
WEB_CONCURRENCY=2
PORT=5000
